# n8n Environment Variables
# Generate a secret key (e.g. openssl rand -hex 16)
N8N_ENCRYPTION_KEY=your_secure_encryption_key_here

# The domain name and subdomain where n8n will be hosted
DOMAIN_NAME=example.com
SUBDOMAIN=n8n

# Timezone (e.g. Europe/Paris)
GENERIC_TIMEZONE=Europe/Paris

# Supabase Postgres Connection for n8n internal data
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_HOST=aws-0-eu-central-1.pooler.supabase.com
DB_POSTGRESDB_PORT=6543
DB_POSTGRESDB_USER=postgres.yourprojectid
# Replace with your actual database password
DB_POSTGRESDB_PASSWORD=your_supabase_db_password

# Redis password for queue/cache
REDIS_PASSWORD=your_secure_redis_password
